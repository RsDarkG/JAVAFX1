<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="302.0" prefWidth="373.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.CalEcuacionesController">
    <children>

        <!-- Selector tipo de ecuación -->
        <Label layoutX="20.0" layoutY="22.0" text="Tipo de ecuación:" />
        <ComboBox fx:id="COMBOTIPO" layoutX="140.0" layoutY="18.0" onAction="#COMBOTIPO" prefWidth="150.0" />

        <!-- Etiqueta de la fórmula (cambia según el tipo) -->
        <Label fx:id="LBLFORMULA" layoutX="20.0" layoutY="55.0" text="ax + b = c" />

        <!-- Lineal: a, b = c -->
        <!-- Cuadrática: a, b, c = d -->

        <!-- Campo a -->
        <Label layoutX="20.0" layoutY="95.0" text="a =" />
        <TextField fx:id="FIELDA" layoutX="40.0" layoutY="90.0" prefHeight="25.0" prefWidth="69.0" promptText="Ej: 5" />

        <!-- Campo b -->
        <Label layoutX="123.0" layoutY="96.0" text="b =" />
        <TextField fx:id="FIELDB" layoutX="143.0" layoutY="91.0" prefHeight="25.0" prefWidth="69.0" promptText="Ej: 6" />

        <!-- Campo c (en cuadrática es coeficiente, en lineal es el lado derecho) -->
        <Label fx:id="LBLC" layoutX="224.0" layoutY="95.0" text="c =" />
        <TextField fx:id="FIELDC" layoutX="244.0" layoutY="90.0" prefHeight="25.0" prefWidth="69.0" promptText="Ej: 7" />

        <!-- Campo d = lado derecho (solo cuadrática) -->
        <Label fx:id="LBLD" layoutX="285.0" layoutY="95.0" text="= d" visible="false" />
        <TextField fx:id="FIELDD" layoutX="305.0" layoutY="90.0" prefWidth="45.0" promptText="ej: 2" visible="false" />

        <!-- Botones -->
        <Button fx:id="BUTTONCALCULAR" layoutX="80.0" layoutY="140.0" onAction="#BUTTONCALCULAR" prefHeight="32.0" prefWidth="100.0" styleClass="btn-igual" text="Calcular" />

        <Button fx:id="BUTTONLIMPIAR" layoutX="195.0" layoutY="140.0" onAction="#BUTTONLIMPIAR" prefHeight="32.0" prefWidth="100.0" styleClass="btn-borrar" text="Limpiar" />

        <!-- Resultado -->
        <Label layoutX="20.0" layoutY="195.0" text="Resultado:" />
        <TextField fx:id="FIELDRESULTADO" editable="false" layoutX="20.0" layoutY="215.0" prefWidth="330.0" promptText="Resultado" />

    </children>
</AnchorPane>
